# Database SQL gestito, consigliato Neon/Vercel Postgres/Supabase Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/giafarm?sslmode=require"

# Auth.js / NextAuth
AUTH_SECRET="genera-con-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
APP_BASE_URL="http://localhost:3000"

# Google OAuth dedicato al progetto GiaFarm
AUTH_GOOGLE_ID="google-oauth-client-id"
AUTH_GOOGLE_SECRET="google-oauth-client-secret"

# Bootstrap autorizzazioni
ADMIN_EMAILS="admin@example.com"

# Google Drive documentale
GOOGLE_DRIVE_ROOT_FOLDER_ID="drive-folder-id-root-giafarm"

# Gmail scanner dedicata
GOOGLE_SCANNER_EMAIL="scansioni@giafarm.example"
GOOGLE_GMAIL_SCANNER_LABEL="INBOX"

# Service account Google con delega domain-wide oppure account tecnico autorizzato
GOOGLE_SERVICE_ACCOUNT_EMAIL="service-account@giafarm-project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
