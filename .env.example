# Supabase PostgreSQL via Prisma
# Runtime Vercel/serverless: usare Supavisor transaction pooler, porta 6543, con pgbouncer=true.
DATABASE_URL="postgresql://prisma.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma CLI/migrazioni: usare la direct connection Supabase, non il transaction pooler.
DIRECT_URL="postgresql://postgres:DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Supabase public client, opzionale per future integrazioni frontend. Non usato da Prisma.
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxx"

# Auth.js / NextAuth
AUTH_SECRET="genera-con-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
APP_BASE_URL="http://localhost:3000"

# Produzione Vercel:
# NEXTAUTH_URL="https://gia-farm.vercel.app"
# AUTH_URL="https://gia-farm.vercel.app"
# APP_BASE_URL="https://gia-farm.vercel.app"

# Google OAuth dedicato al progetto GiaFarm
AUTH_GOOGLE_ID="google-oauth-client-id"
AUTH_GOOGLE_SECRET="google-oauth-client-secret"

# Bootstrap autorizzazioni
ADMIN_EMAILS="admin@example.com,secondo-admin@example.com"

# Google Drive documentale
GOOGLE_DRIVE_ROOT_FOLDER_ID="drive-folder-id-root-giafarm"

# Gmail scanner dedicata
GOOGLE_SCANNER_EMAIL="scansioni@giafarm.example"
GOOGLE_GMAIL_SCANNER_LABEL="INBOX"

# Service account Google con delega domain-wide oppure account tecnico autorizzato
GOOGLE_SERVICE_ACCOUNT_EMAIL="service-account@giafarm-project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
